# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.private-eval/
/Known Fake EMLs/
/Known-good-corpus/
/email-analysis-archive/
/src/lib/email/__tests__/_diagnose.test.ts
/src/lib/email/__tests__/_diagnose-out.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# generated reports and scratch output
*-out.json
*.report.json
*.results.json

# local databases
*.db
*.db-*
*.sqlite
*.sqlite-*
*.sqlite3
*.sqlite3-*
*-wal
*-shm

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local artifacts (launch.json, worktrees, etc.)
/.claude/

# local agent and design-tool state
/.agents/
/.codex/
/.impeccable/
/.worktrees/
